# Salesforce MCP Server URL
MCP_SERVER_URL=https://api.salesforce.com/platform/mcp/v1/platform/sobject-all

# ── External Client Apps (ECA) ────────────────────────────────────────────────
# Two separate ECAs are required because different OAuth scopes cannot share
# the same token without invalidating each other.

# Primary ECA — used for MCP data access (mcp_api scope)
SF_CLIENT_ID=your_primary_eca_client_id

# Secondary ECA — used for Models API + record updates (sfap_api, api scopes)
SF_MODELS_CLIENT_ID=your_secondary_eca_client_id

# Salesforce URLs
SF_LOGIN_URL=https://your-org.my.salesforce.com
SF_TOKEN_URL=https://login.salesforce.com
CALLBACK_URL=http://localhost:3335/oauth/callback

# ── LLM Configuration ─────────────────────────────────────────────────────────

# Salesforce Models API model name (used when Models API toggle is on)
# Options: sfdc_ai__DefaultGPT4Omni, sfdc_ai__DefaultOpenAIGPT4OmniMini, 
#          sfdc_ai__DefaultAnthropic, etc.
SF_MODELS_API_MODEL=sfdc_ai__DefaultOpenAIGPT4OmniMini

# Optional: Anthropic API key (used if Models API is off)
ANTHROPIC_API_KEY=

# Optional: OpenAI API key
OPENAI_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3335
APP_URL=http://localhost:3335
